{
  "name": "root",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "website"
  ],
  "scripts": {
    "format": "prettier -w .",
    "lint": "eslint .",
    "spellcheck": "cspell \"**\" --no-progress",
    "prepare": "husky"
  },
  "devDependencies": {
    "cspell": "^8.14.4",
    "eslint": "^10.2.0",
    "eslint-config-jc": "workspace:*",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-config-jc": "workspace:*",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.58.0"
  }
}
